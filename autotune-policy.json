{
  "apply_network": true,
  "apply_inbounds": true,
  "apply_warp_routing": true,
  "apply_direct_inbound": false,
  "apply_mobile_opt": true,
  "run_mobile_diag": false,
  "disable_panel_tg_conflict": true,
  "run_guard": true,
  "guard_mode": "smoke",
  "guard_retries": 3,
  "guard_retry_delay": 10,
  "guard_ready_timeout_sec": 90,
  "guard_ready_interval_sec": 3,
  "network_timeout_sec": 30,
  "nl_profile_probe_cache_ttl_sec": 1800,
  "nl_profile_probe_cache_stale_ttl_sec": 21600,
  "nl_profile_probe_max_workers": 8,
  "nl_profile_sticky_primary_delta_ms": 75.0,
  "nl_profile_timeout_sec": 120,
  "direct_inbound_timeout_sec": 60,
  "mobile_opt_timeout_sec": 60,
  "mobile_diag_timeout_sec": 60,
  "restart_xui_timeout_sec": 60,
  "guard_timeout_sec": 120,
  "performance_history_limit": 20,
  "performance_alert_enabled": true,
  "performance_alert_min_runs": 6,
  "performance_alert_consecutive_runs": 2,
  "performance_alert_min_total_sec": 2.0,
  "performance_alert_factor": 2.5,
  "performance_alert_min_interval_sec": 21600,
  "performance_ignore_live_probe_runs": true,
  "performance_infer_live_probe_stage_sec": 10.0,
  "performance_infer_cached_probe_stage_sec": 2.0,
  "stage_performance_alert_enabled": true,
  "stage_performance_alert_min_runs": 6,
  "stage_performance_alert_consecutive_runs": 2,
  "stage_performance_alert_min_stage_sec": 0.3,
  "stage_performance_alert_factor": 2.0,
  "stage_performance_alert_min_interval_sec": 21600,
  "notify_admin_on_failure": true,
  "notify_admin_on_recovery": true,
  "summary_enabled": true,
  "summary_min_runs": 6,
  "summary_min_coverage_sec": 43200,
  "summary_interval_sec": 86400,
  "summary_window_sec": 86400,
  "summary_rollup_days_limit": 14,
  "min_notify_interval_sec": 3600,
  "mtproto_health_check": true,
  "mtproto_health_timeout_sec": 10,
  "whatsapp_proxy_health_check": true,
  "whatsapp_proxy_health_timeout_sec": 10,
  "signal_proxy_health_check": true,
  "signal_proxy_health_timeout_sec": 10
}